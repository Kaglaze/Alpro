   ],
   "source": [
    "def jumlah(n):\n",
    "    if n == 0:\n",
    "        return 0\n",
    "    else:\n",
    "        return n + jumlah(n - 1)\n",
    "\n",
    "n = int(input(\"Masukkan n: \"))\n",
    "total = jumlah(n)\n",
    "\n",
    "print(f\"Jumlah 1 sampai {n} = {total}\")"
   ]
  },
